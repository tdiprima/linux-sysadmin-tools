#!/bin/bash
# Description: Script to update a macOS system using Homebrew
# Author: tdiprima

# Skip casks requiring admin privileges to avoid password prompts
export HOMEBREW_CASK_OPTS="--no-quarantine"

echo "Starting system update using Homebrew..."

# Update Homebrew itself
echo "Updating Homebrew..."
brew update

# Upgrade installed formulas
echo "Upgrading installed packages..."
brew upgrade

# Upgrade installed casks (for apps) - skip those requiring admin privileges
echo "Upgrading installed casks..."
brew upgrade --cask --greedy 2>/dev/null || {
    echo "Some casks skipped (likely require admin privileges)"
    # Try upgrading only casks that don't require sudo
    brew upgrade --cask --no-quarantine --greedy 2>/dev/null || true
}

# Clean up outdated versions
echo "Cleaning up old packages and cache..."
brew cleanup

# Check for any potential issues with Homebrew
echo "Running Homebrew diagnostics..."
brew doctor

#echo "Restarting Homebrew services..." # like databases or servers
#brew services restart --all

echo "System update completed successfully!"
